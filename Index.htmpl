<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<title>🔑 KEYMASTER – SOLID PATROL</title>
<link rel="manifest" href="manifest.json">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/MarkerCluster.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/MarkerCluster.Default.css"/>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Courier New',monospace;background:#0d0d1a;color:#fff;height:100vh;display:flex;flex-direction:column;overflow:hidden}
  #brand-header {background:#111122;border-bottom:3px solid #e53935;padding:12px 20px;display:flex;align-items:center;gap:15px;flex-shrink:0}
  #brand-header img {height:45px;border-radius:4px;object-fit:contain}
  #brand-header h1 {font-size:20px;font-weight:900;color:#fff;letter-spacing:1px;font-family:sans-serif;margin:0}
  .solid-red {color:#e53935}
  #topbar{background:#1a1a2e;border-bottom:1px solid #333;padding:10px 14px;display:flex;flex-direction:column;gap:8px;flex-shrink:0}
  .row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  button{font-family:'Courier New',monospace;cursor:pointer;border:none;border-radius:6px;font-weight:700;transition:opacity .15s}
  .tab-btn{background:#0d0d1a;color:#fff;border:1px solid #e53935;padding:5px 12px;font-size:12px}
  .tab-btn.active{background:#e53935}
  .view-btn{background:transparent;color:#888;border:1px solid #2a2a4a;padding:5px 10px;font-size:12px}
  .view-btn.active{background:#2a2a4a;color:#fff}
  .action-btn{padding:7px 13px;font-size:13px;border-radius:8px;background:#16213e;color:#fff;border:1px solid #4fc3f7}
  #content{flex:1;overflow:hidden;position:relative}
  #map{height:100%;width:100%}
  #status{font-size:11px;color:#aaa;padding:5px}
  .map-search-container {background:rgba(26,26,46,0.9);padding:6px;position:relative;pointer-events:auto;}
  #map-search-input {background:#0d0d1a;color:#fff;border:1px solid #333;padding:8px;width:200px}
</style>
</head>
<body>
<div id="brand-header"><img src="10679.png" alt="Logo"><h1><span class="solid-red">SOLID</span> PATROL 110</h1></div>
<div id="topbar">
  <div class="row">
    <button class="tab-btn active" id="tab-keys" onclick="switchTab('keys')">🔑 KLUCZE</button>
    <button class="tab-btn" id="tab-pilots" onclick="switchTab('pilots')">📡 PILOTY</button>
    <button class="action-btn" onclick="document.getElementById('file-pdf').click()">📄 Wczytaj PDF</button>
  </div>
  <div id="status"></div>
</div>
<div id="content"><div id="map"></div></div>
<!-- (DOPISZEMY TUTAJ RESZTĘ KODU W NASTĘPNYCH WIADOMOŚCIACH) -->
